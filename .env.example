# ==================================================
# Spendora - AI Finance Predictor  |  .env.example
# ==================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# .env is gitignored and will NOT be committed.
# --------------------------------------------------

# Flask secret key — change to a long random string
SECRET_KEY=your-secret-key-here

# Admin panel access
# Comma-separated list of emails that get admin access
ADMIN_EMAILS=your@email.com,another@email.com

# Database path (optional, defaults to database/finance.db)
# DATABASE_PATH=database/finance.db
